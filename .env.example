# FinlyAI Environment Configuration Example
# Copy this file to .env and fill in your values

# Google Gemini API Key (If omitted/blank, the pipeline falls back to mock CFO mode)
GEMINI_API_KEY=your_gemini_api_key_here

# Scheduler Interval (How often Fragment 1 runs in schedule loop, in minutes)
SCHEDULE_INTERVAL_MINUTES=5.0
